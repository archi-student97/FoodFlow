{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$lines = netstat -ano | Select-String ':4000' | Select-String 'LISTENING'; foreach($l in $lines){ $targetPid = ($l -split '\\s+')[-1]; if($targetPid -match '^[0-9]+$'){ taskkill /PID $targetPid /F 2>$null | Out-Null } }; next dev -p 4000\"",
    "build": "next build",
    "start": "next start -p 4000",
    "lint": "eslint"
  },
  "dependencies": {
    "@google/genai": "^2.2.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie": "^1.1.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
